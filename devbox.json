{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.12.0/.schema/devbox.schema.json",
  "description": "Cross-platform CLI tools (macOS + Linux). Mirrors tools from tasks/macos/install (brew, go, rust) where available in nixpkgs.",
  "packages": [
    "atuin@latest",
    "bat@latest",
    "cargo@latest",
    "cmake@latest",
    "coreutils@latest",
    "delta@latest",
    "eza@latest",
    "fd@latest",
    "git-cliff@latest",
    "gnupg@latest",
    "gnused@latest",
    "go-task@latest",
    "go@1.23",
    "htop@latest",
    "jq@latest",
    "nodejs@latest",
    "pass@latest",
    "pipx@latest",
    "pre-commit@latest",
    "python3@latest",
    "ripgrep@latest",
    "rustc@latest",
    "shellcheck@latest",
    "sops@latest",
    "taplo@latest",
    "tmux@latest",
    "wget@latest",
    "xclip@latest",
    "xsel@latest",
    "yamlfmt@latest",
    "yazi@latest",
    "zoxide@latest"
  ],
  "shell": {
    "init_hook": [
      "export PATH=\"$PWD/bin:$PWD/node_modules/.bin:$PATH\""
    ],
    "scripts": {
      "precommit": [
        "sh scripts/hooks/pre-commit"
      ],
      "precommit-install": [
        "npm install",
        "pre-commit install"
      ]
    }
  }
}
