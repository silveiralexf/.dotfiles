{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.12.0/.schema/devbox.schema.json",
  "description": "Cross-platform CLI tools (macOS + Linux). Mirrors tools from tasks/macos/install (brew, go, rust) where available in nixpkgs.",
  "packages": [
    "atuin@latest",
    "bat@latest",
    "btop@latest",
    "cmake@latest",
    "coreutils@latest",
    "delta@latest",
    "eza@latest",
    "fd@latest",
    "git-cliff@latest",
    "glibcLocales@latest",
    "glibcLocalesUtf8@latest",
    "gnupg@latest",
    "gnused@latest",
    "go-task@latest",
    "go@1.23",
    "chafa@latest",
    "delve@latest",
    "gofumpt@latest",
    "golangci-lint@latest",
    "govulncheck@latest",
    "htop@latest",
    "jq@latest",
    "kubectl@latest",
    "lua5_1@latest",
    "lua5_4@latest",
    "luarocks@latest",
    "markdownlint-cli@latest",
    "nodejs@latest",
    "pass@latest",
    "picard@latest",
    "pipx@latest",
    "pre-commit@latest",
    "python3@latest",
    "dockerfile-language-server@latest",
    "gopls@latest",
    "helm-ls@latest",
    "lua-language-server@latest",
    "marksman@latest",
    "prettierd@latest",
    "terraform-ls@latest",
    "vscode-langservers-extracted@latest",
    "yaml-language-server@latest",
    "ripgrep@latest",
    "ruff@latest",
    "rust-analyzer@latest",
    "shellcheck@latest",
    "shfmt@latest",
    "stylua@latest",
    "sops@latest",
    "sshfs@latest",
    "taplo@latest",
    "tmux@latest",
    "tmuxp@latest",
    "viu@latest",
    "wget@latest",
    "xclip@latest",
    "xsel@latest",
    "yamlfmt@latest",
    "yazi@latest",
    "zoxide@latest"
  ],
  "shell": {
    "init_hook": [
      "export PATH=\"$PWD/bin:$PWD/node_modules/.bin:$PATH\""
    ],
    "scripts": {
      "precommit": [
        "sh scripts/hooks/pre-commit"
      ],
      "precommit-install": [
        "pre-commit install"
      ]
    }
  }
}
