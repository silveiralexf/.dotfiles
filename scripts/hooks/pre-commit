#!/bin/sh
set -eu

# Changelog is generated by the CI pipeline on push to main/master (.github/workflows/changelog.yaml)

SKIPPERS="CHANGELOG.md README.md"

# Run Pre-Commit checks
if command -v pre-commit >/dev/null; then
  exec git ls-files -- . | grep -vE "${SKIPPERS}" | xargs pre-commit run --files
  exit 0
else
  echo 'pre-commit not found.  brew install pre-commit to have it installed' 1>&2
  git add -u
fi
