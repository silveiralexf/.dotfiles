{
  "agents": {
    "code-reviewer": {
      "description": "Reviews config, shell, Lua, YAML, Taskfiles for consistency and plan adherence.",
      "file": "code-reviewer.md",
      "prerequisites": [
        "planner"
      ],
      "role": "quality-gate"
    },
    "config": {
      "delegates_to": [
        "code-reviewer"
      ],
      "description": "Implements config changes in etc/, nvim/, wezterm/, hammerspoon/, yazi/, tmux/, scripts/.",
      "file": "config.md",
      "prerequisites": [
        "planner"
      ],
      "role": "config-editor"
    },
    "planner": {
      "delegates_to": [
        "config",
        "taskfile",
        "code-reviewer"
      ],
      "description": "Strategic Orchestrator. Plans and coordinates agents for dotfiles changes.",
      "file": "planner.md",
      "role": "orchestrator"
    },
    "taskfile": {
      "delegates_to": [
        "code-reviewer"
      ],
      "description": "Taskfile Automation. Edits Taskfile.yml and tasks/*.yml.",
      "file": "taskfile.md",
      "prerequisites": [
        "planner"
      ],
      "role": "automation"
    }
  },
  "skills": [
    {
      "file": "skills/taskfile-validate.sh",
      "name": "taskfile-validate"
    },
    {
      "file": "skills/pre-commit-run.sh",
      "name": "pre-commit-run"
    }
  ],
  "version": "1.0",
  "workflows": {
    "dotfiles-change": {
      "description": "Plan → config/taskfile → review",
      "steps": [
        {
          "action": "create plan",
          "agent": "planner"
        },
        {
          "action": "implement",
          "agent": "config"
        },
        {
          "action": "review",
          "agent": "code-reviewer"
        }
      ]
    }
  }
}
