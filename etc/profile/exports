#!/bin/zsh

# vi: ft=sh

# -----------------------------------------------------------------------------
# Handlers and core OS stuff
# -----------------------------------------------------------------------------

# Locale - ensure UTF-8 in all environments (SSH, tmux, Nexterm)
# LOCALE_ARCHIVE is needed for Nix-provided glibc to find locale data
if [ -z "$LOCALE_ARCHIVE" ]; then
  for _la in /nix/store/*-glibc-locales-*/lib/locale/locale-archive; do
    [ -f "$_la" ] && export LOCALE_ARCHIVE="$_la" && break
  done
  unset _la
fi
export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# Dotfile scripts when available
[ -d "${DOTFILES_SCRIPTS}" ] && export PATH="$PATH:${DOTFILES_SCRIPTS}::"

# GpG settings
export GPG_TTY="$(tty)"

# Man pages path
export MANPATH="/usr/local/man:$MANPATH"

# Format time output just like bash would
export TIMEFMT=$'real\t%E\nuser\t%U\nsys\t%S'

# don't put duplicate lines or lines starting with space in bash history
export HISTCONTROL="ignoredups:erasedups"

# Make some commands not show up in history
export HISTIGNORE="&:ls:cd -:cd:date:* --help:exit:pwd:history:clear:mount:umount:[ \t]*"

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
export HISTSIZE=50000000
export HISTFILESIZE="$HISTSIZE"
export SAVEHIST=$HISTSIZE

# Tmux Profile display
export DISABLE_AUTO_TITLE='true'

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vi'
  export VISUAL='vi'
else
  export EDITOR='nvim'
  export VISUAL='nvim'
fi

# -----------------------------------------------------------------------------
# Terminal colors & display
# -----------------------------------------------------------------------------

# Color settings
export COLORTERM=truecolor

# get some colors on commands with grc when installed
[[ -s "/etc/grc.zsh" ]] && source "/etc/grc.zsh"

# Syntax highlight for LESS command
if command -v source-highlight &>/dev/null 2>&0; then
  export PAGER="less"
  export LESS="-R"
  [ -f "${DOTFILES_SCRIPTS}/src-hilite-lesspipe.sh" ] &&
    export LESSOPEN="| ${DOTFILES_SCRIPTS}/src-hilite-lesspipe.sh %s"
fi

# make less more friendly for non-text input files, see lesspipe(1)
[ -f /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

export FONTCONFIG_PATH=/etc/fonts
# -----------------------------------------------------------------------------
# Coding stuff
# -----------------------------------------------------------------------------

# Golang
export GO111MODULE="on"
export GOPATH="${HOME}/go"
export TINYGOPATH="${HOME}/tinygo"
export TINYGOBIN="${TINYGOPATH}/bin"
export GOBIN="${GOPATH}/bin"
export PATH="${PATH}:/usr/local/go/bin:${GOBIN}:${TINYGOBIN}:${GOROOT}/bin"

# Lua
export LUA_PATH="${HOME}/.dotfiles/lua_modules/share/lua/5.4/?.lua;${HOME}/.dotfiles/lua_modules/share/lua/5.4/?/init.lua;;"
export LUA_CPATH="${HOME}/.dotfiles/lua_modules/lib/lua/5.4/?.so;;"
export PATH="${HOME}/.dotfiles/lua_modules/bin:${PATH}"
eval "$(luarocks path --bin)"

# Ruby
PATH="${PATH}:${HOME}/.gem/ruby/2.7.0/bin"

# Zig
export ZIGPATH="${HOME}/zig"
export ZIGBIN="${ZIGPATH}/bin"
export PATH="${PATH}:${ZIGBIN}"

# -----------------------------------------------------------------------------
# Tools & Utils
# -----------------------------------------------------------------------------

# Common exports for both Linux and MacOS
export PATH="${PATH}:${HOME}"
export PATH="${PATH}:${HOME}/.local/share/nvim/mason/bin"
export PATH="${PATH}:${HOME}/bin"
export PATH="${PATH}:/opt/bin"
export PATH="${PATH}:/opt/local/bin"
export PATH="${PATH}:/opt/nvim/bin"
export PATH="${HOME}/.local/bin:$PATH"
export PATH="${HOME}/.cargo/bin:$PATH"
export PATH="$PATH:${HOME}/.opencode/bin"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

# Git
export PATH="${PATH}:/usr/local/git/bin"
export LG_CONFIG_FILE="${HOME}/.config/lazygit/lazy.yaml"

# Enable Docker build kit by default
export DOCKER_BUILDKIT=1
export BUILDKIT_COLORS=run=green:warning=yellow:error=red:cancel=255,165,0
export BUILDKIT_PROGRESS=plain
export KUBE_EDITOR=nvim
export DOCKER_DEFAULT_PLATFORM=linux/amd64

# atuil shell history
if test -f "$HOME/.atuin/bin/env" &>/dev/null 2>&0; then
  . "$HOME/.atuin/bin/env"
  eval "$(atuin init zsh --disable-up-arrow)"
fi

# Terraform Env
if command -v terraform &>/dev/null 2>&0; then
  mkdir -p "${HOME}/.tfenv"
  export PATH="${PATH}:${HOME}/.tfenv/bin"
fi

# Linux-only exports
if [[ "$(uname)" == "Linux" ]]; then
  # D-Bus session
  export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"

  # Display settings for KeePassXC (running with AppImage)
  export QT_AUTO_SCREEN_SCALE_FACTOR=0
  export QT_SCREEN_SCALE_FACTORS=DP1=1.5 #;DP1=1.5;DP2=1.5;HDMI1=1.5;HDMI2=1.5;VIRTUAL1=1.5;
fi

# MacOS-only exports
if [[ "$(uname)" == "Darwin" ]]; then
  export PATH="${PATH}:/Applications/WezTerm.app/Contents/MacOS"
  export PATH="${PATH}:${HOME}/AppImage"

  # Homebrew basic settings
  export PATH="${PATH}:/opt/homebrew/bin"
  export PATH="${PATH}:/opt/homebrew/opt/socket_vmnet/bin"
  export PATH="${PATH}:/opt/homebrew/sbin"

  # Homebrew setttings for compilers to find zlib
  export LDFLAGS="-L/opt/homebrew/opt/zlib/lib"
  export CPPFLAGS="-I/opt/homebrew/opt/zlib/include"

  # Homebrew pkg-config to find zlib
  export PKG_CONFIG_PATH="/opt/homebrew/opt/zlib/lib/pkgconfig"

  # Homebrew openssl and DYLD library path
  export PATH="/opt/homebrew/opt/openssl@3.0/bin:$PATH"
  export DYLD_LIBRARY_PATH="$(brew --prefix)/lib:$DYLD_LIBRARY_PATH"
  eval "$(/opt/homebrew/bin/brew shellenv)"

  # Prefer gnu-sed as default
  export PATH="${HOMEBREW_PREFIX}/opt/gnu-sed/libexec/gnubin:${PATH}"

  # Rancher
  export PATH="${PATH}:/Applications/Rancher Desktop.app/Contents/Resources/resources/darwin/lima/bin"
  export LIMA_HOME="${HOME}/Library/Application Support/rancher-desktop/lima"
  export PATH="${PATH}:${HOME}/.rd/bin"
fi

# -----------------------------------------------------------------------------
# EOF
# -----------------------------------------------------------------------------
